{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/talbina", "destination": "/index.html" },
    { "source": "/bike", "destination": "/index.html" },
    { "source": "/cab", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
